# ESP32-A1S Secrets Configuration
# 
# Instructions:
#   1. Copy this file to secrets.yaml
#   2. Fill in your actual credentials
#   3. NEVER commit secrets.yaml to git!
#
# To generate an API encryption key, run:
#   openssl rand -base64 32

# WiFi Configuration
wifi_ssid: "Your-WiFi-SSID"
wifi_password: "Your-WiFi-Password"

# Home Assistant API Encryption Key (32-byte base64 encoded)
api_encryption_key: "REPLACE_WITH_YOUR_32_CHAR_BASE64_KEY=="

# OTA Update Password
ota_password: "your-secure-ota-password"

# Fallback Access Point Password (used when WiFi fails)
ap_password: "fallback-password"
